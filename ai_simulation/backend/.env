# Environment
ENVIRONMENT=development
DEBUG=true

# API
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Almas@6060
POSTGRES_DB=ai_simulation
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Code Execution
CODE_EXECUTION_TIMEOUT=30
DOCKER_ENABLED=true
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email (optional)
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=AI Simulation Engine

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:5173

# Monitoring (optional)
ENABLE_PROMETHEUS=false
ENABLE_SENTRY=false
SENTRY_DSN=